<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/registrationLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F9FA">

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EchoVision Registration"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#468CA6"
        android:fontFamily="sans-serif-medium"
        android:paddingBottom="24dp" />

    <!-- Fingerprint Icon -->
    <ImageView
        android:id="@+id/fingerprintIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/ic_lock_idle_lock"

        android:background="@android:color/white"
        android:elevation="6dp"
        android:padding="20dp"
        android:scaleType="centerInside"
        android:contentDescription="Fingerprint Icon"
        android:layout_marginBottom="24dp" />

    <!-- Instruction -->
    <TextView
        android:id="@+id/instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place your finger on the fingerprint sensor to register"
        android:textSize="16sp"
        android:textColor="#555555"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:paddingTop="12dp"
        android:paddingBottom="20dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for authentication..."
        android:textSize="16sp"
        android:textStyle="italic"
        android:textColor="#468CA6"
        android:paddingTop="16dp" />

</LinearLayout>

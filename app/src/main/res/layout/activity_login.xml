<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F9FA">

    <!-- App title -->
    <TextView
        android:id="@+id/loginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EchoVision Login"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#468CA6"
        android:fontFamily="sans-serif-medium"
        android:paddingBottom="24dp" />

    <!-- Fingerprint icon (for better UI feedback) -->
    <ImageView
        android:id="@+id/fingerprintIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        android:contentDescription="Fingerprint Authentication"
        android:layout_marginBottom="24dp"
        android:tint="#468CA6"
        android:background="@android:color/white"
        android:elevation="6dp"
        android:padding="20dp"
        android:scaleType="centerInside"

        tools:ignore="UseAppTint"/>

    <!-- Instruction -->
    <TextView
        android:id="@+id/loginInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Place your finger on the fingerprint sensor to login"

        android:layout_marginBottom="20dp"
        android:textSize="16sp"
        android:textColor="#555555"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"/>



</LinearLayout>
